APP_NAME=RADJATIKET
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# ═══════════════════════════════════════════════════════════════
# PRODUCTION SETTINGS
# ═══════════════════════════════════════════════════════════════
# Untuk production, ubah:
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://radjatiket.com
# ═══════════════════════════════════════════════════════════════

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# ═══════════════════════════════════════════════════════════════
# PRODUCTION DATABASE CONFIGURATION
# ═══════════════════════════════════════════════════════════════
# Untuk production, gunakan MySQL/PostgreSQL:
#
# MySQL:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=radjatiket_production
# DB_USERNAME=radjatiket_user
# DB_PASSWORD=secure-password-here
#
# PostgreSQL:
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=radjatiket_production
# DB_USERNAME=radjatiket_user
# DB_PASSWORD=secure-password-here
# ═══════════════════════════════════════════════════════════════

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# ═══════════════════════════════════════════════════════════════
# QUEUE CONFIGURATION
# ═══════════════════════════════════════════════════════════════
# Untuk production, gunakan redis atau database untuk queue
# Jalankan: php artisan queue:work
# Atau setup supervisor untuk auto-restart queue worker
#
# Redis Queue (Recommended for Production):
# QUEUE_CONNECTION=redis
#
# Database Queue (Good for Small-Medium Traffic):
# QUEUE_CONNECTION=database
#
# Sync (Development Only - No Queue):
# QUEUE_CONNECTION=sync
# ═══════════════════════════════════════════════════════════════

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ═══════════════════════════════════════════════════════════════
# PRODUCTION EMAIL CONFIGURATION
# ═══════════════════════════════════════════════════════════════
# Untuk production, ganti MAIL_MAILER=smtp dan isi konfigurasi berikut:
#
# Gmail SMTP:
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS="noreply@radjatiket.com"
# MAIL_FROM_NAME="RADJATIKET"
#
# Mailgun:
# MAIL_MAILER=mailgun
# MAILGUN_DOMAIN=your-domain.mailgun.org
# MAILGUN_SECRET=your-mailgun-secret
# MAILGUN_ENDPOINT=api.mailgun.net
# MAIL_FROM_ADDRESS="noreply@radjatiket.com"
# MAIL_FROM_NAME="RADJATIKET"
#
# SendGrid:
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.sendgrid.net
# MAIL_PORT=587
# MAIL_USERNAME=apikey
# MAIL_PASSWORD=your-sendgrid-api-key
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS="noreply@radjatiket.com"
# MAIL_FROM_NAME="RADJATIKET"
#
# AWS SES:
# MAIL_MAILER=ses
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_DEFAULT_REGION=ap-southeast-1
# MAIL_FROM_ADDRESS="noreply@radjatiket.com"
# MAIL_FROM_NAME="RADJATIKET"
#
# Mailtrap (Testing):
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_USERNAME=your-mailtrap-username
# MAIL_PASSWORD=your-mailtrap-password
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS="noreply@radjatiket.com"
# MAIL_FROM_NAME="RADJATIKET"
# ═══════════════════════════════════════════════════════════════

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
